// PiQApi.ArchitectureRules/Solution/Fixit/diagram_creation_plan.json
{
  "metadata": {
    "path": "PiQApi.Architecture/Solution/Fixit/diagram_creation_plan.json",
    "version": "1.0",
    "last_updated": "2024-02-22",
    "purpose": "Define sequence and standards for architectural diagram creation"
  },
  "diagram_sequence": {
    "1_solution_level": {
      "project_structure": {
        "purpose": "Define overall solution architecture",
        "diagrams": [
          {
            "name": "SolutionStructure.puml",
            "content": [
              "Project dependencies",
              "Layer boundaries",
              "Core relationships"
            ],
            "source_guides": [
              "ProjectStructure.json",
              "ArchitecturalPrinciples.json"
            ]
          }
        ]
      },
      "layer_interactions": {
        "purpose": "Define cross-cutting patterns",
        "diagrams": [
          {
            "name": "ValidationFlow.puml",
            "content": "Validation chain across layers"
          },
          {
            "name": "ErrorHandling.puml",
            "content": "Error propagation patterns"
          }
        ]
      }
    },
    "2_abstractions_layer": {
      "structure": {
        "purpose": "Define abstractions architecture",
        "diagrams": [
          {
            "name": "CoreContracts.puml",
            "content": [
              "Interface relationships",
              "Abstract types",
              "Framework contracts"
            ],
            "source_guides": [
              "PiQApi.Abstractions_Architecture.json",
              "PiQApi.Abstractions_Interfaces.json"
            ]
          }
        ]
      },
      "domain_models": {
        "purpose": "Show domain model relationships",
        "diagrams": [
          {
            "name": "DomainModels.puml",
            "content": [
              "Value objects",
              "Request/Response models",
              "Primitive types"
            ],
            "source_guides": [
              "PiQApi.Abstractions_Models.json"
            ]
          }
        ]
      },
      "validation_framework": {
        "purpose": "Define validation architecture",
        "diagrams": [
          {
            "name": "ValidationFramework.puml",
            "content": [
              "Validation contracts",
              "Result types",
              "Context relationships"
            ],
            "source_guides": [
              "PiQApi.Abstractions_Validation.json",
              "PiQApi.Solution_CrossCutting_Validation.json"
            ]
          }
        ]
      }
    },
    "3_project_level": {
      "sequence": [
        "Core architecture",
        "Service patterns",
        "Operations structure",
        "Client organization"
      ]
    }
  },
  "diagram_standards": {
    "file_organization": {
      "solution_diagrams": "PiQApi.Architecture/Solution/Diagrams",
      "project_diagrams": "PiQApi.Architecture/Projects/{ProjectName}/Diagrams"
    },
    "naming_conventions": {
      "files": "{Purpose}.puml",
      "components": "PascalCase descriptive names",
      "relationships": "Clear directional indicators"
    },
    "content_rules": {
      "required_elements": [
        "Title and description",
        "Component stereotypes",
        "Clear relationships",
        "Interface markers"
      ],
      "layout": [
        "Logical grouping",
        "Clear hierarchy",
        "Minimal crossing lines",
        "Consistent direction"
      ]
    }
  },
  "implementation_steps": {
    "immediate": [
      "Create Solution structure diagram",
      "Create Abstractions core contracts diagram",
      "Create domain models diagram"
    ],
    "dependencies": {
      "required_tools": [
        "PlantUML extension",
        "Graphviz installation",
        "VS Code or similar editor"
      ]
    }
  }
}