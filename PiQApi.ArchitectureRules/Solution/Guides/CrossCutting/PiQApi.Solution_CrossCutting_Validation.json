// PiQApi.ArchitectureRules/Solution/Guides/CrossCutting/PiQApi.Solution_CrossCutting_Validation.json
{
  "metadata": {
    "path": "PiQApi.Architecture/Solution/Guides/CrossCutting/PiQApi.Solution_CrossCutting_Validation.json",
    "version": "1.0",
    "last_updated": "2024-02-22",
    "purpose": "Define comprehensive validation framework and patterns",
    "dependencies": [
      "PiQApi.Solution_Architecture_ExceptionHandling.json"
    ]
  },
  "core_principles": {
    "validation_rules": {
      "pattern": "Validation logic encapsulated in ValidationRule<T> objects",
      "requirements": [
        "Pure validation logic - no side effects",
        "Composable and reusable",
        "Thread-safe and stateless",
        "Rich error context"
      ]
    },
    "layer_responsibilities": {
      "client_layer": {
        "focus": "Request model validation",
        "scope": [
          "Property completeness",
          "Data type correctness",
          "Size limitations",
          "Format requirements"
        ],
        "timing": "Before operation execution"
      },
      "operations_layer": {
        "focus": "Business rule validation",
        "scope": [
          "Business constraints",
          "State transitions",
          "Resource availability",
          "Operation limits"
        ],
        "timing": "Before service calls"
      },
      "service_layer": {
        "focus": "Technical validation",
        "scope": [
          "Connection state",
          "Authentication",
          "Protocol constraints",
          "Resource limits"
        ],
        "timing": "Before API calls"
      }
    },
    "result_aggregation": {
      "flow": {
        "sequence": [
          "Client validates request",
          "Operations validate business rules",
          "Service validates technical constraints"
        ],
        "result_handling": {
          "aggregation": "Combine errors through chain",
          "early_exit": "Stop on first failure option",
          "error_enhancement": "Each layer adds context"
        }
      }
    }
  },
  "implementation": {
    "validation_rule": {
      "base_contract": {
        "interface": "IValidationRule<T>",
        "methods": [
          "Task<PiQValidationResult> ValidateAsync(T item, PiQValidationContext context, CancellationToken ct)"
        ]
      },
      "concrete_rules": {
        "property_rules": "Validate specific properties/states",
        "composite_rules": "Combine multiple rules",
        "business_rules": "Validate business logic",
        "infrastructure_rules": "Validate system constraints"
      }
    },
    "validation_context": {
      "required_data": [
        "ValidationModeType Mode",
        "CorrelationId Id",
        "IReadOnlyDictionary<string, object> Properties"
      ],
      "propagation": "Passed through validation chain",
      "enhancement": "Each layer can add context"
    },
    "validation_result": {
      "structure": {
        "properties": [
          "bool IsValid",
          "IReadOnlyCollection<ValidationError> Errors",
          "string CorrelationId",
          "ValidationSeverityType Severity"
        ]
      },
      "aggregation": "Multiple results can be combined",
      "error_handling": "Maps to IPiQResult through factory"
    }
  },
  "layer_specific_patterns": {
    "client_validation": {
      "focus": [
        "Request model completeness",
        "Data type correctness",
        "Size/range constraints",
        "Basic relationships"
      ],
      "example_rules": [
        "MailRequestValidator",
        "RecipientValidator",
        "AttachmentValidator"
      ]
    },
    "operations_validation": {
      "focus": [
        "Business rule compliance",
        "Domain invariants",
        "Complex relationships",
        "State transitions"
      ],
      "example_rules": [
        "MailOperationValidator",
        "CalendarRuleValidator",
        "FolderHierarchyValidator"
      ]
    },
    "service_validation": {
      "focus": [
        "EWS constraints",
        "Resource availability",
        "Technical limitations",
        "Infrastructure state"
      ],
      "example_rules": [
        "PropertySetValidator",
        "ConnectionValidator",
        "AuthenticationValidator"
      ]
    }
  },
  "validation_flow": {
    "request_handling": {
      "sequence": [
        "Client validates request model",
        "Operations validate business rules",
        "Service validates technical constraints",
        "Results aggregate back through chain"
      ],
      "error_handling": {
        "early_exit": "Stop at first validation failure",
        "full_validation": "Collect all validation errors",
        "mode_dependent": "Behavior controlled by ValidationMode"
      }
    },
    "response_mapping": {
      "pattern": {
        "validation_failure": "Map to IPiQResult with errors",
        "success": "Proceed with operation",
        "partial_validation": "Include warnings in result"
      }
    }
  },
  "immutability_requirements": {
    "validation_rules": {
      "pattern": "Rules must be immutable",
      "configuration": "Set during construction",
      "state": "No mutable fields"
    },
    "validation_context": {
      "pattern": "Immutable after creation",
      "properties": "ReadOnly dictionary",
      "enhancement": "Create new instance"
    },
    "validation_results": {
      "pattern": "Immutable once created",
      "errors": "ReadOnly collection",
      "aggregation": "Create new result"
    }
  }
}
