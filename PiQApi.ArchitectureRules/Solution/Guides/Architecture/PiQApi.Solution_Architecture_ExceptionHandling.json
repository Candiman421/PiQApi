// PiQApi.ArchitectureRules/Solution/Guides/Architecture/PiQApi.Solution_Architecture_ExceptionHandling.json
{
  "metadata": {
    "path": "PiQApi.Architecture/Solution/Guides/Architecture/PiQApi.Solution_Architecture_ExceptionHandling.json",
    "version": "1.0",
    "last_updated": "2024-02-22",
    "purpose": "Define comprehensive error handling and result patterns"
  },
  "core_principles": {
    "expected_vs_exceptional": {
      "expected_failures": {
        "pattern": "PiQResult<T>",
        "location": "PiQApi.Abstractions/Results",
        "when_to_use": "For all expected business operation failures",
        "examples": [
          "Validation failures",
          "Not found conditions",
          "Permission issues",
          "Business rule violations"
        ]
      },
      "exceptional_conditions": {
        "pattern": "Exception hierarchy",
        "location": "PiQApi.Exchange.Core/Exceptions",
        "when_to_use": "For unexpected system/infrastructure failures",
        "examples": [
          "Network failures",
          "Configuration errors",
          "Infrastructure issues",
          "Security violations"
        ]
      }
    }
  },
  "solution_structure": {
    "PiQApi.Abstractions": {
      "interfaces": {
        "IPiQResult": {
          "summary": "Base result interface - named to avoid collision with System.Threading.Tasks.Result",
          "location": "Results/IPiQResult.cs",
          "members": [
            "bool IsSuccess",
            "ExchangeError? Error"
          ]
        },
        "IPiQResult<T>": {
          "extends": "IPiQResult",
          "location": "Results/IPiQResult{T}.cs",
          "additional_members": [
            "T? Value"
          ]
        },
        "IResultError": {
          "location": "Results/IResultError.cs",
          "members": [
            "ErrorCodeType Code",
            "string Message",
            "string CorrelationId",
            "DateTimeOffset Timestamp",
            "ValidationSeverityType Severity",
            "IReadOnlyDictionary<string,object> Context"
          ]
        },
        "IPiQException": {
          "location": "Exceptions/IPiQException.cs",
          "members": [
            "string ErrorCode",
            "string CorrelationId",
            "DateTimeOffset Timestamp",
            "IReadOnlyDictionary<string,object> AdditionalData"
          ]
        }
      },
      "base_classes": {
        "PiQServiceException": {
          "location": "Exceptions/PiQServiceException.cs",
          "implements": "IPiQException",
          "features": [
            "Modern serialization",
            "Rich context",
            "Correlation tracking"
          ]
        },
        "PiQResult": {
          "location": "Results/PiQResult.cs",
          "implements": "IPiQResult",
          "notes": "Named to avoid collision with System.Threading.Tasks.Result"
        }
      }
    },
    "PiQApi.Exchange.Core": {
      "results": {
        "ExchangeResult": {
          "location": "Results/ExchangeResult.cs",
          "extends": "PiQResult",
          "notes": "Exchange prefix due to Exchange-specific implementation"
        },
        "ExchangeResult<T>": {
          "location": "Results/ExchangeResult{T}.cs",
          "extends": "ExchangeResult"
        },
        "ExchangeError": {
          "location": "Results/ExchangeError.cs",
          "implements": "IResultError",
          "notes": "Exchange prefix for API-specific error details"
        }
      },
      "exceptions": {
        "base": {
          "CoreServiceException": {
            "location": "Exceptions/Base/CoreServiceException.cs",
            "extends": "PiQServiceException"
          }
        },
        "validation": {
          "ExchangeValidationException": {
            "location": "Exceptions/Validation/ExchangeValidationException.cs",
            "extends": "CoreServiceException"
          }
        }
      }
    }
  },
  "implementation_standards": {
    "factories": {
      "IResultFactory": {
        "location": "PiQApi.Abstractions/Factories",
        "purpose": "Create result objects in a standard way",
        "members": [
          "IPiQResult<T> Success<T>(T value)",
          "IPiQResult<T> Failure<T>(string code, string message)",
          "IExchangeResult<T> ExchangeSuccess<T>(T value, ServiceOperationStatusType status, string requestId)",
          "IExchangeResult<T> ExchangeFailure<T>(string code, string message, ServiceOperationStatusType status, string requestId)"
        ],
        "notes": "Keep in abstractions to allow different implementations"
      },
      "ResultFactory": {
        "location": "PiQApi.Exchange.Core/Factories",
        "requirements": [
          "Must inject ICorrelationContext",
          "Must inject ILogger",
          "Must handle all error context properly",
          "Must maintain correlation across operations"
        ],
        "best_practices": [
          "Use static factory methods for common scenarios",
          "Maintain consistent error creation patterns",
          "Log all failure creation",
          "Support error context enrichment"
        ]
      }
    },
    "error_handling": {
      "result_pattern_usage": {
        "do": [
          "Use for all public API methods",
          "Include correlation IDs",
          "Provide rich error context",
          "Map domain errors to proper types"
        ],
        "dont": [
          "Mix exceptions and results",
          "Lose error context",
          "Use for unexpected failures",
          "Catch general exceptions in transformers"
        ],
        "example": {
          "code": "public async Task<IPiQResult<MailItem>> SendMailAsync(MailRequest request) { ... }"
        }
      },
      "exception_usage": {
        "do": [
          "Use for infrastructure failures",
          "Include stack traces",
          "Add correlation context",
          "Log at throw site"
        ],
        "dont": [
          "Use for business logic",
          "Catch and rethrow unnecessarily",
          "Lose original context",
          "Mix domains in single exception"
        ]
      }
    },
    "correlation": {
      "requirements": {
        "all_results_must": [
          "Include CorrelationId",
          "Maintain parent/child relationships",
          "Support activity tracking",
          "Enable distributed tracing"
        ],
        "all_errors_must": [
          "Include operation context",
          "Support aggregation",
          "Enable trace correlation",
          "Maintain causal chains"
        ]
      },
      "context_propagation": {
        "pattern": "Use ICorrelationContext throughout",
        "scope": "Pass through all layers",
        "storage": "Maintain in AsyncLocal where needed",
        "tracing": "Support OpenTelemetry integration"
      }
    }
  },
  "validation": {
    "result_aggregation": {
      "pattern": "Collect all validation errors before returning",
      "implementation": "Use PiQValidationResult",
      "transformation": "Map to ExchangeError properly",
      "context": "Maintain validation metadata"
    },
    "hierarchy": {
      "operations": {
        "client_validation": "Basic request validation",
        "business_validation": "Domain rules and constraints",
        "service_validation": "Exchange-specific validations"
      },
      "error_handling": {
        "pattern": "Aggregate up through chain",
        "response": "Return comprehensive error list",
        "context": "Maintain validation chain details"
      }
    }
  },
  "naming_standards": {
    "piq_prefix_rules": {
      "required_for": [
        "Types colliding with .NET framework",
        "Core abstraction types",
        "Shared validation types"
      ],
      "examples": {
        "PiQResult": "Collides with multiple Result types",
        "PiQValidationResult": "Collides with DataAnnotations",
        "PiQValidationContext": "Collides with DataAnnotations"
      }
    },
    "exchange_prefix_rules": {
      "required_for": [
        "Exchange API specific types",
        "Exchange operation results",
        "Exchange-specific errors"
      ],
      "examples": {
        "ExchangeResult": "Exchange-specific result type",
        "ExchangeError": "Exchange error details",
        "ExchangeValidationException": "Exchange validation"
      }
    }
  },
  "patterns": {
    "immutability": {
      "error_types": {
        "pattern": "Use C# records",
        "properties": "Use init-only setters",
        "collections": "Use immutable collections",
        "context": "Immutable dictionaries for metadata"
      },
      "results": {
        "pattern": "Immutable after construction",
        "modifications": "Return new instances",
        "collections": "Return read-only views"
      }
    },
    "serialization": {
      "modern_patterns": {
        "records": {
          "use_for": [
            "Error types",
            "Validation results",
            "Operation contexts"
          ],
          "benefits": [
            "Immutability",
            "Value semantics",
            "Built-in support"
          ]
        },
        "exceptions": {
          "required_attributes": ["[Serializable]"],
          "required_methods": [
            "Serialization constructor",
            "GetObjectData override",
            "Proper base calls"
          ],
          "context_handling": "Use init-only properties where possible"
        }
      }
    }
  }
}
