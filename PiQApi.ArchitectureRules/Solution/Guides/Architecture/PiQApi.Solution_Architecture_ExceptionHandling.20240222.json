    "validation_integration": {
      "result_transformation": {
        "pattern": "Use ResultFactory for consistent mapping",
        "key_points": [
          "Preserve validation context",
          "Maintain error hierarchies",
          "Keep correlation chains",
          "Handle severity levels"
        ],
        "example": {
          "code": [
            "public static class ResultFactory",
            "{",
            "    public static IPiQResult<T> FromValidationResult<T>(",
            "        PiQValidationResult validationResult)",
            "    {",
            "        return new PiQResult<T>",
            "        {",
            "            IsSuccess = validationResult.IsValid,",
            "            Error = new ExchangeError(",
            "                validationResult.Errors,",
            "                validationResult.CorrelationId,",
            "                validationResult.Severity)",
            "        };",
            "    }",
            "}"
          ]
        }
      },
