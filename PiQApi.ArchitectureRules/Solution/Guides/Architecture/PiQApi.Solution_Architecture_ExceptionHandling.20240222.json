        "examples": [
          "Network failures",
          "Configuration errors",
          "Infrastructure issues",
          "Security violations"
        ],
        "validation_interaction": {
          "validation_exceptions": "Only for validation framework failures",
          "result_mapping": "Don't map validation results to exceptions",
