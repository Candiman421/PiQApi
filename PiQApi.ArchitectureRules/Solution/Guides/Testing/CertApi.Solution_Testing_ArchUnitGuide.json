  "arch_unit_patterns": {
    "test_organization": {
      "core_principles": {
        "architecture_loading": {
          "pattern": "Load once at class level for performance",
          "implementation": {
            "example": [
              "private static readonly Architecture Architecture = new ArchLoader()",
              "    .LoadAssemblies(typeof(ICertResult).Assembly)",
              "    .Build();"
            ],
            "key_points": [
              "Static readonly field",
              "Load target assemblies explicitly",
              "Build once at startup"
            ]
          }
        },
        "layer_definitions": {
          "pattern": "Define IObjectProvider<T> fields for reuse",
          "examples": [
            {
              "layer": {
                "code": "private readonly IObjectProvider<IType> AbstractionsLayer = Types()",
                "pattern": "Namespace-based layer definition",
                "usage": "Base layer grouping"
              },
              "components": {
                "code": "private readonly IObjectProvider<Interface> ValidationContracts = Interfaces()",
                "pattern": "Feature-specific grouping",
                "usage": "Focused rule testing"
              }
            }
          ]
        }
      }
    },
    "rule_patterns": {
      "basic_rules": {
        "dependency_rules": {
          "example": "Types().That().Are(LayerA).Should().NotDependOnAny(LayerB)",
          "variations": [
            "NotDependOnAny - Prevent dependencies",
            "OnlyDependOn - Restrict dependencies",
            "ResideInNamespace - Location rules"
          ]
        },
        "naming_rules": {
          "example": "Classes().That().ImplementInterface(IType).Should().HaveNameStartingWith('prefix')",
          "variations": [
            "HaveNameStartingWith",
            "HaveNameEndingWith",
            "HaveNameMatching"
          ]
        }
      },
      "custom_conditions": {
        "pattern": "Create reusable conditions for complex checks",
        "implementation": {
          "example": [
            "private static ArchCondition<IType> BeImmutable()",
            "{",
            "    return new ArchCondition<IType>('be immutable',",
            "        type => type.GetFields().All(f => f.IsReadOnly) &&",
            "               type.GetProperties().All(p => !p.HasSetter || p.HasInitOnlySetter));",
            "}"
          ],
          "usage": "Rules().Should().MeetCondition(BeImmutable())"
        }
      }
    },
    "test_writing": {
      "from_json_guides": {
        "approach": "Direct validation of architectural rules",
        "process": [
          "Extract core principles from guide",
          "Convert to concrete ArchUnit rules",
          "Group related rules in partial class files",
          "Use guide examples for test cases"
        ],
        "example": {
