// PiQApi.ArchitectureRules/Projects/PiQApi.Abstractions/Guides/PiQApi.Abstractions_Validation.json
{
  "metadata": {
    "path": "PiQApi.Architecture/Projects/PiQApi.Abstractions/Guides/PiQApi.Abstractions_Validation.json",
    "version": "1.0",
    "last_updated": "2024-02-22",
    "purpose": "Define validation contracts and base types",
    "dependencies": [
      "PiQApi.Abstractions_Architecture.json",
      "PiQApi.Solution_CrossCutting_Validation.json",
      "PiQApi.Solution_Architecture_ExceptionHandling.20240222.json"
    ]
  },
  "validation_contracts": {
    "core_interfaces": {
      "IValidationRule<T>": {
        "purpose": "Encapsulate single validation rule",
        "location": "Validation/IValidationRule.cs",
        "signature": {
          "methods": [
            "Task<CertValidationResult> ValidateAsync(T item, CertValidationContext context, CancellationToken ct)"
          ],
          "requirements": [
            "Pure validation only",
            "No side effects",
            "Thread-safe",
            "Proper cancellation"
          ]
        }
      },
      "IValidationRuleSet<T>": {
        "purpose": "Group related validation rules",
        "location": "Validation/IValidationRuleSet.cs",
        "signature": {
          "methods": [
            "IReadOnlyCollection<IValidationRule<T>> GetRules()"
          ],
          "requirements": [
            "Immutable rule collection",
            "No rule execution",
            "No state management"
          ]
        }
      },
      "IValidationProcessor": {
        "purpose": "Execute validation chains",
        "location": "Validation/IValidationProcessor.cs",
        "signature": {
          "methods": [
            "Task<CertValidationResult> ValidateAsync<T>(T item, IValidationRule<T> rule, CertValidationContext context, CancellationToken ct)",
            "Task<CertValidationResult> ValidateAsync<T>(T item, IValidationRuleSet<T> ruleSet, CertValidationContext context, CancellationToken ct)"
          ]
        }
      }
    },
    "validation_context": {
      "CertValidationContext": {
        "purpose": "Carry validation state",
        "location": "Validation/CertValidationContext.cs",
        "properties": [
          "ValidationModeType Mode - Controls validation behavior",
          "CertCorrelationId Id - Chain tracking",
          "IReadOnlyDictionary<string, object> Properties - Context data"
        ],
        "requirements": [
          "Immutable after creation",
          "Thread-safe",
          "Rich context",
          "Correlation support"
        ]
      }
    },
    "validation_results": {
      "CertValidationResult": {
        "purpose": "Validation outcome with details",
        "location": "Validation/CertValidationResult.cs",
        "properties": [
          "bool IsValid - Overall validation state",
          "IReadOnlyCollection<ValidationError> Errors - Validation failures",
          "string CorrelationId - Result tracking",
          "ValidationSeverityType Severity - Result severity"
        ],
        "methods": {
          "factories": [
            "Success(string correlationId)",
            "Failure(IEnumerable<ValidationError> errors, string correlationId)"
          ],
          "combination": [
            "CombineWith(CertValidationResult other)"
          ]
        }
      },
      "ValidationError": {
        "purpose": "Individual validation failure",
        "location": "Validation/ValidationError.cs",
        "properties": [
          "string Code - Error identifier",
          "string Message - Error description",
          "ValidationSeverityType Severity - Error severity",
          "IReadOnlyDictionary<string, object> Context - Error data"
        ]
      }
    }
  },
  "validation_behaviors": {
    "mode_handling": {
      "ValidationModeType": {
        "Standard": {
          "behavior": "Normal validation flow",
          "failure_handling": "Continue on warning"
        },
        "Strict": {
          "behavior": "Enhanced validation",
          "failure_handling": "Fail on warning"
        },
        "Lenient": {
          "behavior": "Minimal validation",
          "failure_handling": "Warnings as info"
        }
      }
    },
    "severity_handling": {
      "ValidationSeverityType": {
        "Error": {
          "impact": "Validation failure",
          "handling": "Stop processing"
        },
        "Warning": {
          "impact": "Potential issue",
          "handling": "Mode dependent"
        },
        "Info": {
          "impact": "Notification only",
          "handling": "Continue always"
        }
      }
    }
  },
  "result_aggregation": {
    "principles": {
      "rule_results": {
        "requirements": [
          "Maintain all errors",
          "Preserve severity",
          "Keep correlation",
          "Combine context"
        ]
      },
      "chain_results": {
        "requirements": [
          "Layer-specific context",
          "Error relationships",
          "Severity escalation",
          "Context enhancement"
        ]
      }
    }
  },
  "implementation_rules": {
    "validation_flow": {
      "execution": {
        "required": [
          "Async execution",
          "Cancellation support",
          "Context propagation",
          "Error aggregation"
        ]
      },
      "error_handling": {
        "required": [
          "Clear error messages",
          "Rich context",
          "Proper categorization",
          "Severity assignment"
        ]
      }
    },
    "immutability": {
      "context": {
        "rules": [
          "Immutable properties",
          "Read-only collections",
          "Thread-safe design",
          "No state modification"
        ]
      },
      "results": {
        "rules": [
          "Immutable after creation",
          "Read-only error collections",
          "Thread-safe combination",
          "No result modification"
        ]
      }
    }
  },
  "forbidden_patterns": {
    "validation_rules": {
      "dont": [
        "Include business logic",
        "Cause side effects",
        "Maintain state",
        "Skip cancellation"
      ]
    },
    "context_handling": {
      "dont": [
        "Modify existing context",
        "Share context instances",
        "Skip correlation",
        "Expose mutable state"
      ]
    },
    "result_handling": {
      "dont": [
        "Modify existing results",
        "Skip error details",
        "Ignore severity",
        "Break immutability"
      ]
    }
  }
}