// CertApi.ArchitectureRules/Projects/CertApi.Abstractions/Guides/CertApi.Abstractions_Results.json
{
  "metadata": {
    "path": "CertApi.Architecture/Projects/CertApi.Abstractions/Guides/CertApi.Abstractions_Results.json",
    "version": "1.0",
    "last_updated": "2024-02-22",
    "purpose": "Define result pattern contracts and usage",
    "dependencies": [
      "CertApi.Abstractions_Architecture.json",
      "CertApi.Solution_Architecture_ExceptionHandling.20240222.json"
    ]
  },
  "result_patterns": {
    "core_contracts": {
      "ICertResult": {
        "purpose": "Base result type for all operations",
        "location": "Results/ICertResult.cs",
        "members": [
          "bool IsSuccess - Operation outcome",
          "IResultError? Error - Failure details"
        ],
        "usage": "Base interface for all results",
        "naming": "Cert prefix due to Result type collisions"
      },
      "ICertResult<T>": {
        "purpose": "Generic result with value",
        "location": "Results/ICertResult{T}.cs",
        "members": [
          "T? Value - Success payload",
          "Inherits ICertResult members"
        ],
        "usage": "Operations returning values"
      },
      "IResultError": {
        "purpose": "Rich error context",
        "location": "Results/IResultError.cs",
        "members": [
          "ErrorCodeType Code - Error classification",
          "string Message - Error description",
          "string CorrelationId - Error tracking",
          "DateTimeOffset Timestamp - When error occurred",
          "ValidationSeverityType Severity - Error severity",
          "IReadOnlyDictionary<string,object> Context - Additional data"
        ]
      }
    },
    "factory_contracts": {
      "IResultFactory": {
        "purpose": "Create consistent result objects",
        "location": "Results/IResultFactory.cs",
        "methods": [
          "ICertResult<T> Success<T>(T value)",
          "ICertResult<T> Failure<T>(string code, string message)",
          "ICertResult<T> FromValidationResult<T>(CertValidationResult validationResult)"
        ],
        "principles": [
          "Consistent result creation",
          "Proper error context",
          "Validation integration",
          "Correlation tracking"
        ]
      }
    }
  },
  "error_handling": {
    "error_types": {
      "classification": {
        "validation_errors": {
          "usage": "Business rule violations",
          "severity": "Warning or Error",
          "context": "Validation details"
        },
        "business_errors": {
          "usage": "Expected business failures",
          "severity": "Error",
          "context": "Business state"
        },
        "technical_errors": {
          "usage": "Infrastructure issues",
          "severity": "Error",
          "context": "Technical details"
        }
      }
    },
    "error_aggregation": {
      "principles": {
        "composition": "Combine multiple errors",
        "hierarchy": "Maintain error relationships",
        "context": "Preserve error details"
      }
    }
  },
  "validation_integration": {
    "result_mapping": {
      "patterns": {
        "validation_to_result": {
          "pattern": "Map validation results to ICertResult",
          "requirements": [
            "Preserve validation errors",
            "Maintain severity",
            "Keep correlation",
            "Include context"
          ]
        }
      }
    }
  },
  "implementation_rules": {
    "immutability": {
      "requirements": [
        "All result types immutable",
        "Error context read-only",
        "No state modification",
        "Thread-safe design"
      ]
    },
    "error_context": {
      "required_data": [
        "Error classification",
        "Correlation tracking",
        "Timing information",
        "Severity level"
      ]
    },
    "correlation": {
      "requirements": [
        "All results correlated",
        "Error chain tracking",
        "Operation linking",
        "Context preservation"
      ]
    }
  },
  "forbidden_patterns": {
    "result_usage": {
      "dont": [
        "Mix exceptions and results",
        "Modify result state",
        "Lose error context",
        "Skip correlation"
      ]
    },
    "implementation": {
      "dont": [
        "Add behavior methods",
        "Include business logic",
        "Reference concrete types",
        "Add external dependencies"
      ]
    }
  }
}